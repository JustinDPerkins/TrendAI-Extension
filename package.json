{
  "name": "trendmicro-security-scanner",
  "displayName": "TrendAI™ Security Scanner",
  "description": "Integrate TrendAI™ TMAS and Template Scanner for vulnerability, malware, secrets, and IaC scanning",
  "version": "0.1.0",
  "publisher": "trendmicro",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "security",
    "vulnerability",
    "malware",
    "secrets",
    "terraform",
    "cloudformation",
    "iac",
    "trend micro",
    "tmas"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "trendmicro.scanDirectory",
        "title": "Scan Directory",
        "category": "TrendAI™"
      },
      {
        "command": "trendmicro.scanFile",
        "title": "Scan File",
        "category": "TrendAI™"
      },
      {
        "command": "trendmicro.scanImage",
        "title": "Scan Container Image",
        "category": "TrendAI™"
      },
      {
        "command": "trendmicro.scanTemplate",
        "title": "Scan IaC Template",
        "category": "TrendAI™"
      },
      {
        "command": "trendmicro.scanTerraformProject",
        "title": "Scan Terraform Project",
        "category": "TrendAI™"
      },
      {
        "command": "trendmicro.setApiToken",
        "title": "Set API Token",
        "category": "TrendAI™"
      },
      {
        "command": "trendmicro.refreshResults",
        "title": "Refresh Results",
        "category": "TrendAI™",
        "icon": "$(refresh)"
      },
      {
        "command": "trendmicro.showResultsPanel",
        "title": "Show Results Dashboard",
        "category": "TrendAI™",
        "icon": "$(dashboard)"
      },
      {
        "command": "trendmicro.clearResults",
        "title": "Clear Results",
        "category": "TrendAI™",
        "icon": "$(clear-all)"
      },
      {
        "command": "trendmicro.buildAndScanDockerfile",
        "title": "Build & Scan Dockerfile",
        "category": "TrendAI™",
        "icon": "$(package)"
      },
      {
        "command": "trendmicro.launchAIScanner",
        "title": "Scan LLM Application",
        "category": "TrendAI™",
        "icon": "$(hubot)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "trendmicro-security",
          "title": "TrendAI™ Security",
          "icon": "resources/icons/shield.svg"
        }
      ]
    },
    "views": {
      "trendmicro-security": [
        {
          "id": "trendmicro.resultsView",
          "name": "Scan Results"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "trendmicro.scanFile",
          "group": "trendmicro@1",
          "when": "explorerResourceIsFolder || resourceExtname"
        },
        {
          "command": "trendmicro.scanTemplate",
          "group": "trendmicro@2",
          "when": "resourceExtname == .tf || resourceExtname == .yaml || resourceExtname == .yml || resourceExtname == .json"
        },
        {
          "command": "trendmicro.scanTerraformProject",
          "group": "trendmicro@3",
          "when": "explorerResourceIsFolder"
        },
        {
          "command": "trendmicro.buildAndScanDockerfile",
          "group": "trendmicro@4",
          "when": "resourceFilename == Dockerfile || resourceFilename =~ /Dockerfile\\..*/ || resourceFilename =~ /.*\\.dockerfile/"
        }
      ],
      "editor/context": [
        {
          "command": "trendmicro.scanFile",
          "group": "trendmicro@1"
        },
        {
          "command": "trendmicro.scanTemplate",
          "group": "trendmicro@2",
          "when": "resourceExtname == .tf || resourceExtname == .yaml || resourceExtname == .yml || resourceExtname == .json"
        }
      ],
      "view/title": [
        {
          "command": "trendmicro.refreshResults",
          "when": "view == trendmicro.resultsView",
          "group": "navigation"
        },
        {
          "command": "trendmicro.clearResults",
          "when": "view == trendmicro.resultsView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "TrendAI™ Security Scanner",
      "properties": {
        "trendmicro.visionOneRegion": {
          "type": "string",
          "default": "api.xdr.trendmicro.com",
          "enum": [
            "api.xdr.trendmicro.com",
            "api.au.xdr.trendmicro.com",
            "api.eu.xdr.trendmicro.com",
            "api.in.xdr.trendmicro.com",
            "api.xdr.trendmicro.co.jp",
            "api.sg.xdr.trendmicro.com",
            "api.xdr.sg.trendmicro.com"
          ],
          "description": "Vision One API region endpoint"
        },
        "trendmicro.tmasPath": {
          "type": "string",
          "default": "",
          "description": "Path to TMAS binary (leave empty for auto-download)"
        },
        "trendmicro.scanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan files on save"
        },
        "trendmicro.severityThreshold": {
          "type": "string",
          "default": "medium",
          "enum": [
            "critical",
            "high",
            "medium",
            "low",
            "negligible"
          ],
          "description": "Minimum severity level to report"
        },
        "trendmicro.enableVulnerabilities": {
          "type": "boolean",
          "default": true,
          "description": "Enable vulnerability scanning"
        },
        "trendmicro.enableMalware": {
          "type": "boolean",
          "default": true,
          "description": "Enable malware scanning (container images only)"
        },
        "trendmicro.enableSecrets": {
          "type": "boolean",
          "default": true,
          "description": "Enable secrets scanning"
        },
        "trendmicro.tmasRegion": {
          "type": "string",
          "default": "us-east-1",
          "enum": [
            "us-east-1",
            "eu-central-1",
            "ap-southeast-1",
            "ap-southeast-2",
            "ap-northeast-1",
            "ap-south-1"
          ],
          "description": "TMAS Vision One region for cloud features"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "js-yaml": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/trendmicro/vscode-security-scanner"
  }
}
