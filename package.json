{
  "name": "trendai-security-scanner",
  "displayName": "TrendAI™ Security Scanner",
  "description": "Integrate TrendAI™ TMAS and Template Scanner for vulnerability, malware, secrets, and IaC scanning",
  "version": "0.1.0",
  "publisher": "JustinDPerkins",
  "icon": "resources/icons/App-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "security",
    "vulnerability",
    "malware",
    "secrets",
    "terraform",
    "cloudformation",
    "iac",
    "trend micro",
    "trendai",
    "trendai security scanner",
    "trendai security",
    "trendai security extension",
    "trendai security extension for vscode",
    "trendai security extension for cursor",
    "trendai security extension for vscode",
    "tmas",
    "llm",
    "ai security",
    "prompt injection"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "trendai.scan",
        "title": "Scan (IaC, Secrets, Vulns)",
        "category": "TrendAI™",
        "icon": "$(shield)"
      },
      {
        "command": "trendai.scanLLMEndpoint",
        "title": "LLM Scan (AI Security)",
        "category": "TrendAI™",
        "icon": "$(hubot)"
      },
      {
        "command": "trendai.buildAndScanDockerfile",
        "title": "Build & Scan Dockerfile",
        "category": "TrendAI™",
        "icon": "$(package)"
      },
      {
        "command": "trendai.setApiToken",
        "title": "Set API Token",
        "category": "TrendAI™"
      },
      {
        "command": "trendai.showResultsPanel",
        "title": "Show Results Dashboard",
        "category": "TrendAI™",
        "icon": "$(dashboard)"
      },
      {
        "command": "trendai.refreshResults",
        "title": "Refresh Results",
        "category": "TrendAI™",
        "icon": "$(refresh)"
      },
      {
        "command": "trendai.clearResults",
        "title": "Clear Results",
        "category": "TrendAI™",
        "icon": "$(clear-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "trendai-security",
          "title": "TrendAI™ Security",
          "icon": "resources/icons/trendai-logo.svg"
        }
      ]
    },
    "views": {
      "trendai-security": [
        {
          "id": "trendai.resultsView",
          "name": "Scan Results"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "trendai.scan",
          "group": "trendai@1",
          "when": "explorerResourceIsFolder || resourceExtname"
        },
        {
          "command": "trendai.buildAndScanDockerfile",
          "group": "trendai@2",
          "when": "resourceFilename == Dockerfile || resourceFilename =~ /Dockerfile\\..*/ || resourceFilename =~ /.*\\.dockerfile/"
        }
      ],
      "editor/context": [
        {
          "command": "trendai.scan",
          "group": "trendai@1"
        }
      ],
      "view/title": [
        {
          "command": "trendai.refreshResults",
          "when": "view == trendai.resultsView",
          "group": "navigation"
        },
        {
          "command": "trendai.clearResults",
          "when": "view == trendai.resultsView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "TrendAI™ Security Scanner",
      "properties": {
        "trendai.visionOneRegion": {
          "type": "string",
          "default": "api.xdr.trendmicro.com",
          "enum": [
            "api.xdr.trendmicro.com",
            "api.au.xdr.trendmicro.com",
            "api.eu.xdr.trendmicro.com",
            "api.in.xdr.trendmicro.com",
            "api.xdr.trendmicro.co.jp",
            "api.sg.xdr.trendmicro.com",
            "api.mea.xdr.trendmicro.com",
            "api.uk.xdr.trendmicro.com",
            "api.usgov.xdr.trendmicro.com"
          ],
          "enumDescriptions": [
            "United States",
            "Australia",
            "Germany",
            "India",
            "Japan",
            "Singapore",
            "United Arab Emirates",
            "United Kingdom",
            "United States (Government)"
          ],
          "description": "Vision One API region endpoint"
        },
        "trendai.tmasPath": {
          "type": "string",
          "default": "",
          "description": "Path to TMAS binary (leave empty for auto-download)"
        },
        "trendai.scanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan files on save"
        },
        "trendai.severityThreshold": {
          "type": "string",
          "default": "medium",
          "enum": [
            "critical",
            "high",
            "medium",
            "low",
            "negligible"
          ],
          "description": "Minimum severity level to report"
        },
        "trendai.enableVulnerabilities": {
          "type": "boolean",
          "default": true,
          "description": "Enable vulnerability scanning"
        },
        "trendai.enableMalware": {
          "type": "boolean",
          "default": true,
          "description": "Enable malware scanning (container images only)"
        },
        "trendai.enableSecrets": {
          "type": "boolean",
          "default": true,
          "description": "Enable secrets scanning"
        },
        "trendai.tmasRegion": {
          "type": "string",
          "default": "us-east-1",
          "enum": [
            "us-east-1",
            "ca-central-1",
            "eu-central-1",
            "eu-west-2",
            "me-central-1",
            "ap-south-1",
            "ap-northeast-1",
            "ap-southeast-1",
            "ap-southeast-2"
          ],
          "enumDescriptions": [
            "United States",
            "Canada",
            "Germany",
            "United Kingdom",
            "United Arab Emirates",
            "India",
            "Japan",
            "Singapore",
            "Australia"
          ],
          "description": "TMAS cloud region"
        },
        "trendai.useTerraformPlan": {
          "type": "boolean",
          "default": true,
          "description": "Generate Terraform plan JSON for more accurate scanning (requires terraform CLI and cloud credentials)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/vsce": "^2.15.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "js-yaml": "^4.1.0"
  },
  "author": {
    "name": "Justin Perkins"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JustinDPerkins/TrendAI-Extension"
  },
  "bugs": {
    "url": "https://github.com/JustinDPerkins/TrendAI-Extension/issues"
  },
  "homepage": "https://github.com/JustinDPerkins/TrendAI-Extension#readme",
  "overrides": {
    "undici": "6.19.2"
  }
}
